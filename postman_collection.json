{
  "info": {
    "_postman_id": "d6e7d8d5-1a3d-4d2d-8c3c-b10a10a10a10",
    "name": "GraphQL Blog API",
    "description": "Apollo GraphQL API collection for auth, posts, and comments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/graphql",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "postId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.register && json.data.register.token) {",
                  "  pm.collectionVariables.set('token', json.data.register.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Register($input: RegisterInput!) {\n  register(input: $input) {\n    token\n    user {\n      id\n      name\n      email\n      createdAt\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"name\": \"Demo User\",\n    \"email\": \"demo@example.com\",\n    \"password\": \"password123\"\n  }\n}"
              }
            },
            "url": "{{baseUrl}}"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.login && json.data.login.token) {",
                  "  pm.collectionVariables.set('token', json.data.login.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Login($input: LoginInput!) {\n  login(input: $input) {\n    token\n    user {\n      id\n      name\n      email\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"email\": \"demo@example.com\",\n    \"password\": \"password123\"\n  }\n}"
              }
            },
            "url": "{{baseUrl}}"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query Me {\n  me {\n    id\n    name\n    email\n    createdAt\n    updatedAt\n  }\n}",
                "variables": "{}"
              }
            },
            "url": "{{baseUrl}}"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "List Posts - Full Fields",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query Posts {\n  posts {\n    id\n    title\n    content\n    createdAt\n    updatedAt\n    author {\n      id\n      name\n      email\n    }\n    comments {\n      id\n      content\n      createdAt\n      author {\n        id\n        name\n        email\n      }\n    }\n  }\n}",
                "variables": "{}"
              }
            },
            "url": "{{baseUrl}}"
          }
        },
        {
          "name": "List Posts - Minimal Fields",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query PostsMinimal {\n  posts {\n    id\n    title\n    author {\n      name\n    }\n  }\n}",
                "variables": "{}"
              }
            },
            "url": "{{baseUrl}}"
          }
        },
        {
          "name": "Get Post By ID",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query Post($id: ID!) {\n  post(id: $id) {\n    id\n    title\n    content\n    author {\n      id\n      name\n      email\n    }\n    comments {\n      id\n      content\n      author {\n        id\n        name\n      }\n    }\n  }\n}",
                "variables": "{\n  \"id\": \"{{postId}}\"\n}"
              }
            },
            "url": "{{baseUrl}}"
          }
        },
        {
          "name": "Create Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.createPost && json.data.createPost.id) {",
                  "  pm.collectionVariables.set('postId', json.data.createPost.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CreatePost($input: CreatePostInput!) {\n  createPost(input: $input) {\n    id\n    title\n    content\n    createdAt\n    author {\n      id\n      name\n      email\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"title\": \"First GraphQL Post\",\n    \"content\": \"This post was created from Postman using a JWT-protected GraphQL mutation.\"\n  }\n}"
              }
            },
            "url": "{{baseUrl}}"
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation CreateComment($input: CreateCommentInput!) {\n  createComment(input: $input) {\n    id\n    content\n    createdAt\n    author {\n      id\n      name\n      email\n    }\n    post {\n      id\n      title\n    }\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"postId\": \"{{postId}}\",\n    \"content\": \"This is a comment from Postman.\"\n  }\n}"
              }
            },
            "url": "{{baseUrl}}"
          }
        }
      ]
    }
  ]
}
